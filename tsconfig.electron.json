{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist/electron",
    "rootDir": "src/electron",
    "declaration": true
  },
  "include": ["src/electron/**/*"],
  "exclude": ["node_modules"]
}
